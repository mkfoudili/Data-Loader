# ============================================================
# T5 – Dual DB Ingestion : Environment Variables
# ============================================================
# 1. Copie ce fichier : cp .env.example .env
# 2. Remplis PG_PASSWORD et TSDB_PASSWORD avec ton mot de passe


# --- PostgreSQL (Standard) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=mellitiesi2023
PG_DB=m6_thermal

# DSN construit automatiquement par le script :
# postgresql://{PG_USER}:{PG_PASSWORD}@{PG_HOST}:{PG_PORT}/{PG_DB}

# --- TimescaleDB (même instance PostgreSQL, DB différente) ---
TSDB_HOST=localhost
TSDB_PORT=5432
TSDB_USER=postgres
TSDB_PASSWORD=mellitiesi2023
TSDB_DB=m6_thermal_tsdb

# DSN construit automatiquement par le script :
# postgresql://{TSDB_USER}:{TSDB_PASSWORD}@{TSDB_HOST}:{TSDB_PORT}/{TSDB_DB}

# --- ETL Output Directory ---
ETL_DIR=data/processed
